# Variáveis para o stack de produção (docker-compose.prod.yml).
# Copie este arquivo como `.env.production` no servidor e ajuste os valores.
# Gere senhas/secrets fortes com: openssl rand -base64 32

# ---------- Postgres ----------
POSTGRES_USER=franciosi
POSTGRES_PASSWORD=x4X6/RG6|8Nz
POSTGRES_DB=grupo_franciosi

DATABASE_URL=postgresql://franciosi:x4X6/RG6|8Nz@postgres:5432/grupo_franciosi?schema=public

# ---------- API ----------
JWT_SECRET=COLOQUE_UMA_STRING_ALEATORIA_DE_64_CARACTERES_AQUI
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=60

# Domínios permitidos via CORS (separados por vírgula).
CORS_ORIGIN=https://grupofranciosi.agrigestao.tech,https://pwa.grupofranciosi.agrigestao.tech

# Após o primeiro deploy, defina RUN_SEED=0 para pular o seed nos restarts.
RUN_SEED=1

# Build da PWA. Vazio = mesma origem (recomendado, nginx do PWA proxia para a API).
VITE_PWA_API_URL=

# ---------- Módulo de BI (Apache Superset) ----------
# Versão da imagem oficial apache/superset.
SUPERSET_VERSION=4.1.1

# Segredos do Superset (gere com: openssl rand -base64 42).
SUPERSET_SECRET_KEY=COLOQUE_UMA_STRING_ALEATORIA_LONGA_AQUI
SUPERSET_GUEST_TOKEN_SECRET=COLOQUE_OUTRA_STRING_ALEATORIA_LONGA_AQUI

# Banco de metadados do Superset (container superset-db dedicado).
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=TROQUE_ESTA_SENHA
SUPERSET_DB_NAME=superset

# Admin do Superset — também usado como service account pela API para gerar
# guest tokens. Faça login na UI do Superset com estas credenciais.
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=TROQUE_ESTA_SENHA
SUPERSET_ADMIN_EMAIL=admin@grupofranciosi.agrigestao.tech

# Domínio do painel autorizado a embutir os dashboards (CORS + frame-ancestors).
SUPERSET_PANEL_ORIGIN=https://grupofranciosi.agrigestao.tech

# URL interna (rede docker) que a API usa para falar com o Superset.
SUPERSET_BASE_URL=http://superset:8088
# URL pública do Superset (usada pelo iframe embutido no painel).
SUPERSET_PUBLIC_URL=https://bi.grupofranciosi.agrigestao.tech

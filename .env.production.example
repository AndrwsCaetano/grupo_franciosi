# Variáveis para o stack de produção (docker-compose.prod.yml).
# Copie este arquivo como `.env.production` e ajuste os valores.

# ---------- Postgres ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-em-producao
POSTGRES_DB=grupo_franciosi

# DATABASE_URL apontando para o serviço `postgres` interno do compose.
# Se trocar usuário/senha acima, atualize aqui também.
DATABASE_URL=postgresql://postgres:troque-em-producao@postgres:5432/grupo_franciosi?schema=public

# ---------- API ----------
# Use uma string longa e aleatória (ex.: openssl rand -hex 64).
JWT_SECRET=troque-por-uma-string-aleatoria-de-no-minimo-64-caracteres
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=60

# Origens permitidas na API (CORS), separadas por vírgula se houver mais de uma
# (ex.: painel https://admin.exemplo.com e PWA https://pwa.exemplo.com).
CORS_ORIGIN=https://admin.exemplo.com,https://pwa.exemplo.com

# Após o primeiro deploy o seed é idempotente, mas você pode pular para acelerar:
# RUN_SEED=0

# ---------- Web (painel) ----------
# Porta no host (default 80). Com Caddy na frente pode manter 80 ou usar outra.
# WEB_PORT=80

# ---------- PWA (motorista) ----------
# Porta no host (default 8080). Com Caddy, use subdomínio em CADDY_PWA_DOMAIN.
# PWA_PORT=8080
# Build da PWA: vazio = mesma origem do nginx da PWA (recomendado). Senão URL pública da API:
# VITE_PWA_API_URL=https://admin.exemplo.com

# ---------- Caddy (HTTPS) — opcional ----------
# Domínio do painel (e API via proxy do nginx web). Obrigatório se usar docker-compose.caddy.yml.
# CADDY_ADMIN_DOMAIN=admin.exemplo.com
# Subdomínio da PWA (opcional; omita se acessar só por IP/porta).
# CADDY_PWA_DOMAIN=pwa.exemplo.com

# Variáveis para o stack de produção (docker-compose.prod.yml).
# Copie este arquivo como `.env.production` no servidor e ajuste os valores.
# Gere senhas/secrets fortes com: openssl rand -base64 32

# ---------- Postgres ----------
POSTGRES_USER=franciosi
POSTGRES_PASSWORD=x4X6/RG6|8Nz
POSTGRES_DB=grupo_franciosi

DATABASE_URL=postgresql://franciosi:x4X6/RG6|8Nz@postgres:5432/grupo_franciosi?schema=public

# ---------- API ----------
JWT_SECRET=COLOQUE_UMA_STRING_ALEATORIA_DE_64_CARACTERES_AQUI
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=60

# Domínios permitidos via CORS (separados por vírgula).
CORS_ORIGIN=https://grupofranciosi.agrigestao.tech,https://pwa.grupofranciosi.agrigestao.tech

# Após o primeiro deploy, defina RUN_SEED=0 para pular o seed nos restarts.
RUN_SEED=1

# Build da PWA. Vazio = mesma origem (recomendado, nginx do PWA proxia para a API).
VITE_PWA_API_URL=

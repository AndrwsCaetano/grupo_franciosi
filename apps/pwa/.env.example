# Em desenvolvimento: deixe comentado ou vazio para usar o proxy do Vite
# (mesma origem → sem CORS). Se definir, o browser chama a API direto e a API
# precisa listar esta origem em CORS_ORIGIN.
# VITE_API_URL=http://localhost:4000

# Alvo do proxy quando VITE_API_URL está vazio (só `npm run dev` no PWA)
# VITE_API_PROXY_TARGET=http://localhost:4000

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DataSourceType {
  MARIADB
  POSTGRES
  ORACLE
  SQLSERVER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  active       Boolean  @default(true)
  /// Quando true, o usuário tem acesso a todas as opções (super-admin),
  /// independentemente de perfis ou liberações pontuais.
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profiles            UserProfile[]
  permissionOverrides UserPermission[]
  dashboards          UserDashboard[]
  supersetDashboards  UserSupersetDashboard[]
  refreshTokens       RefreshToken[]
  drivers             Driver[]
  fuelingsCreated     VehicleFueling[] @relation("FuelingCreatedBy")

  // ---- Posto de Combustível ----
  fuelPointAccess       UserFuelPointAccess[]
  fuelDispensings       FuelDispensing[]     @relation("FuelDispensingOperator")
  fuelTransfersCreated  FuelTransfer[]       @relation("FuelTransferCreatedBy")
  fuelTransfersAccepted FuelTransfer[]       @relation("FuelTransferAcceptedBy")
  fuelErpImportsValidated FuelErpImport[]    @relation("FuelErpImportValidatedBy")
}

model Profile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserProfile[]
  permissions ProfilePermission[]
}

model UserProfile {
  userId     String
  profileId  String
  assignedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([userId, profileId])
}

/// Opção do sistema (menu, ação, módulo). Código estável para checagem na API e no front.
model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  profilePermissions ProfilePermission[]
  userPermissions    UserPermission[]
}

/// Liberação por perfil
model ProfilePermission {
  profileId    String
  permissionId String
  granted      Boolean @default(true)

  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([profileId, permissionId])
}

/// Override direto no usuário (concede ou revoga em relação ao que vier dos perfis)
model UserPermission {
  userId       String
  permissionId String
  granted      Boolean

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model DataSource {
  id           String         @id @default(cuid())
  name         String
  type         DataSourceType
  host         String
  port         Int
  databaseName String
  username     String
  /// Senha cifrada ou texto — em produção usar KMS/Vault e apenas referência
  passwordEnc  String
  ssl          Boolean        @default(false)
  extra        Json?
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  dashboards Dashboard[]
}

/// Dashboard dinâmico (consulta/view em banco externo). `definition` guarda SQL, parâmetros, layout.
model Dashboard {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  definition   Json
  dataSourceId String?
  dataSource   DataSource? @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments UserDashboard[]
}

/// Quais dashboards cada usuário pode abrir (liberação explícita)
model UserDashboard {
  userId      String
  dashboardId String
  assignedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@id([userId, dashboardId])
}

/// Dashboard publicado no Apache Superset e embutido no painel via guest token.
/// `embeddedUuid` é o UUID gerado ao habilitar "Embed dashboard" na UI do Superset.
model SupersetDashboard {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String?
  embeddedUuid String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments UserSupersetDashboard[]
}

/// Quais dashboards do Superset cada usuário pode abrir (liberação explícita)
model UserSupersetDashboard {
  userId              String
  supersetDashboardId String
  assignedAt          DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboard SupersetDashboard @relation(fields: [supersetDashboardId], references: [id], onDelete: Cascade)

  @@id([userId, supersetDashboardId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Cadastro de veículo. `plate` é única.
model Vehicle {
  id              String   @id @default(cuid())
  plate           String   @unique
  brand           String
  model           String
  /// Capacidade do tanque em litros (0–9999).
  fuelTankLiters  Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments DriverVehicleAssignment[]
  fuelings    VehicleFueling[]
}

/// Cadastro de motorista. CPF único; pode (opcionalmente) referenciar um usuário do sistema.
model Driver {
  id                  String   @id @default(cuid())
  userId              String?
  /// Nome em CAIXA ALTA (normalizado pelo backend).
  name                String
  birthDate           DateTime @db.Date
  /// CPF apenas em dígitos (sem máscara).
  cpf                 String   @unique
  /// Número da CNH em CAIXA ALTA.
  licenseNumber       String
  licenseIssueDate    DateTime @db.Date
  licenseExpiryDate   DateTime @db.Date
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user          User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignments   DriverVehicleAssignment[]
  fuelings      VehicleFueling[]
  refreshTokens DriverRefreshToken[]

  @@index([userId])
}

model DriverRefreshToken {
  id        String   @id @default(cuid())
  driverId  String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
}

/// Vínculo motorista <-> veículo por período. `endDate` nulo = vínculo ainda em aberto.
/// Regra de negócio (validada no service):
///  - um motorista só pode ter UM vínculo aberto por vez;
///  - uma placa só pode ter UM vínculo aberto por vez (precisa finalizar para liberar).
model DriverVehicleAssignment {
  id          String    @id @default(cuid())
  driverId    String
  vehicleId   String
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([driverId])
  @@index([vehicleId])
  @@index([driverId, endDate])
  @@index([vehicleId, endDate])
}

/// Apontamento de abastecimento de veículo.
/// `createdAt` (dt_lancamento) e `createdById` (id_lancador admin, quando houver) são imutáveis após criação.
/// `driverNameSnapshot` guarda o nome do motorista no momento do lançamento.
/// `dataSincronizacao`: instante em que o servidor persistiu o registro (sync concluído).
model VehicleFueling {
  id                 String    @id @default(uuid())
  driverId           String
  vehicleId          String
  /// Snapshot do nome do motorista (CAIXA ALTA) na hora do lançamento.
  driverNameSnapshot String
  fuelDate           DateTime  @db.Date
  /// Quantidade abastecida (litros), com 2 casas.
  quantityLiters     Decimal   @db.Decimal(10, 2)
  /// Hodômetro / quilometragem do veículo no momento do abastecimento.
  odometerKm         Int?
  /// Caminho relativo do comprovante salvo no servidor.
  receiptImagePath   String?
  notes              String?
  /// Preenchido pelo app motorista para evitar duplicatas ao reenviar a fila offline.
  offlineClientId    String?   @unique
  /// Momento em que o registro foi gravado no servidor (sincronização).
  dataSincronizacao  DateTime? @map("data_sincronizacao")
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  createdBy User?   @relation("FuelingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([driverId])
  @@index([vehicleId])
  @@index([fuelDate])
  @@index([createdAt])
}

// =====================================================================
// MÓDULO: POSTO DE COMBUSTÍVEL (frota interna - novo, isolado)
// Não confundir com VehicleFueling (abastecimento externo em posto de rua).
// Aqui modelamos o posto/comboio próprio, seus estoques, equipamentos
// (máquinas agrícolas / veículos), apontamentos operacionais,
// transferências entre pontos e imports do ERP Compass.
// =====================================================================

enum FuelPointType {
  POSTO
  COMBOIO
}

enum MachineryStatus {
  ATIVO
  MANUTENCAO
  INATIVO
}

enum FuelSyncStatus {
  PENDENTE
  SINCRONIZADO
  ERRO
}

enum FuelTransferStatus {
  PENDENTE
  ACEITA
  RECUSADA
}

enum FuelStockMovementType {
  ABASTECIMENTO
  TRANSFERENCIA_SAIDA
  TRANSFERENCIA_ENTRADA
  NF_ENTRADA
}

enum FuelErpImportKind {
  EQUIPAMENTO
  NF_ENTRADA
}

enum FuelErpImportStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

/// Catálogo de produtos de combustível/aditivo (Diesel S10, S500, Arla 32...).
model FuelProduct {
  id        String   @id @default(cuid())
  name      String   @unique
  /// Unidade padrão (litros, kg...). Guardado como texto por flexibilidade.
  unit      String   @default("L")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks       FuelStock[]
  dispensings  FuelDispensing[]
  transfers    FuelTransfer[]
  movements    FuelStockMovement[]
  machineries  Machinery[]
}

/// Ponto de abastecimento: posto fixo ou comboio (caminhão-tanque).
model FuelPoint {
  id                String        @id @default(cuid())
  type              FuelPointType
  name              String        @unique
  /// Capacidade máxima somando todos os compartimentos (litros).
  maxCapacityLiters Int
  active            Boolean       @default(true)
  /// Preenchido quando um usuário com fuel_station.validate homologa o ponto
  /// vindo do ERP. Ponto não validado não aparece no bootstrap do operador.
  validatedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  stocks         FuelStock[]
  dispensings    FuelDispensing[]
  movements      FuelStockMovement[]
  transfersOut   FuelTransfer[]         @relation("FuelTransferOrigin")
  transfersIn    FuelTransfer[]         @relation("FuelTransferDest")
  userAccess     UserFuelPointAccess[]
}

/// Estoque atual de um produto em um ponto. Chave única (pointId, productId).
model FuelStock {
  id                String   @id @default(cuid())
  pointId           String
  productId         String
  /// Quantidade em litros (2 casas).
  quantityLiters    Decimal  @db.Decimal(12, 2) @default(0)
  /// Reserva mínima para alerta. 0 = sem alerta.
  minReserveLiters  Decimal  @db.Decimal(12, 2) @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  point   FuelPoint    @relation(fields: [pointId], references: [id], onDelete: Cascade)
  product FuelProduct  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([pointId, productId])
  @@index([pointId])
  @@index([productId])
}

/// Máquina/equipamento que abastece no posto (trator, caminhão, colheitadeira...).
/// Chega do ERP e precisa ser validado antes de ficar disponível para apontamento.
model Machinery {
  id                String           @id @default(cuid())
  tag               String           @unique
  name              String
  /// Categoria / tipo livre (ex: "Trator", "Caminhão", "Colheitadeira").
  category          String
  defaultProductId  String?
  /// Última leitura do horímetro conhecida (horas, 2 casas).
  hourMeter         Decimal          @db.Decimal(12, 2) @default(0)
  /// Última leitura do odômetro conhecida (km inteiros).
  odometerKm        Int              @default(0)
  status            MachineryStatus  @default(ATIVO)
  /// Identificador vindo do ERP Compass (quando importado).
  erpExternalId     String?          @unique
  /// Preenchido pelo validador ao aprovar o import do ERP.
  validatedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  defaultProduct FuelProduct?     @relation(fields: [defaultProductId], references: [id], onDelete: SetNull)
  dispensings    FuelDispensing[]

  @@index([status])
}

/// Apontamento (abastecimento operacional) feito pelo operador do posto/comboio.
/// Modelagem separada de VehicleFueling: aqui a transação debita estoque
/// do ponto e atualiza os medidores da máquina.
model FuelDispensing {
  id                 String          @id @default(cuid())
  machineryId        String
  pointId            String
  productId          String
  liters             Decimal         @db.Decimal(12, 2)
  hourMeterReported  Decimal?        @db.Decimal(12, 2)
  kmReported         Int?
  operatorUserId     String
  /// Preenchido pelo app do operador para deduplicar reenvios offline.
  offlineClientId    String?         @unique
  syncStatus         FuelSyncStatus  @default(PENDENTE)
  errorMsg           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  machinery    Machinery   @relation(fields: [machineryId], references: [id], onDelete: Restrict)
  point        FuelPoint   @relation(fields: [pointId], references: [id], onDelete: Restrict)
  product      FuelProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  operator     User        @relation("FuelDispensingOperator", fields: [operatorUserId], references: [id], onDelete: Restrict)

  @@index([machineryId])
  @@index([pointId])
  @@index([productId])
  @@index([createdAt])
  @@index([syncStatus])
}

/// Transferência de combustível entre pontos (ex: posto -> comboio).
/// Regra de negócio: debita origem ao criar; só credita destino ao aceitar;
/// se recusada, restaura o saldo da origem.
model FuelTransfer {
  id               String              @id @default(cuid())
  originPointId    String
  destPointId      String
  productId        String
  liters           Decimal             @db.Decimal(12, 2)
  status           FuelTransferStatus  @default(PENDENTE)
  observation      String?
  createdByUserId  String
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  originPoint FuelPoint   @relation("FuelTransferOrigin", fields: [originPointId], references: [id], onDelete: Restrict)
  destPoint   FuelPoint   @relation("FuelTransferDest", fields: [destPointId], references: [id], onDelete: Restrict)
  product     FuelProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy   User        @relation("FuelTransferCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  acceptedBy  User?       @relation("FuelTransferAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([originPointId])
  @@index([destPointId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

/// Log imutável de todo o movimento de estoque de um produto em um ponto.
/// deltaLiters é positivo (entrada) ou negativo (saída).
/// referenceId aponta para FuelDispensing/FuelTransfer/FuelErpImport conforme "type".
model FuelStockMovement {
  id           String                 @id @default(cuid())
  pointId      String
  productId    String
  deltaLiters  Decimal                @db.Decimal(12, 2)
  type         FuelStockMovementType
  referenceId  String?
  createdAt    DateTime               @default(now())

  point   FuelPoint    @relation(fields: [pointId], references: [id], onDelete: Cascade)
  product FuelProduct  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([pointId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

/// Fila de dados vindos do ERP (Compass) aguardando validação humana.
/// payload guarda o registro bruto (equipamento a cadastrar ou NF de entrada).
model FuelErpImport {
  id                String               @id @default(cuid())
  kind              FuelErpImportKind
  payload           Json
  status            FuelErpImportStatus  @default(PENDENTE)
  validatedByUserId String?
  validatedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  validatedBy User? @relation("FuelErpImportValidatedBy", fields: [validatedByUserId], references: [id], onDelete: SetNull)

  @@index([kind])
  @@index([status])
}

/// Log auditável das tentativas de sincronização com o ERP (push/pull).
model FuelSyncLog {
  id            String   @id @default(cuid())
  /// Categoria do registro sincronizado: APONTAMENTO, TRANSFERENCIA ou ERP (import).
  tipo          String
  referenceId   String
  status        String
  attempts      Int      @default(1)
  lastAttemptAt DateTime?
  erpResponse   Json?
  createdAt     DateTime @default(now())

  @@index([tipo, referenceId])
  @@index([status])
  @@index([createdAt])
}

/// Vínculo usuário <-> ponto de abastecimento que ele opera.
/// Bootstrap do operador só retorna dados dos pontos aqui listados.
model UserFuelPointAccess {
  userId     String
  pointId    String
  assignedAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  point FuelPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@id([userId, pointId])
  @@index([userId])
  @@index([pointId])
}

# Porta 5434 (padrão) ou 5433 se o compose expuser as duas.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/grupo_franciosi?schema=public"
PORT=4000
# Origens permitidas (CORS), separadas por vírgula.
# O código já inclui localhost:5173 por padrão se esta variável não existir.
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_DAYS=60

# PWA motorista (opcional — se omitido, reutiliza JWT_SECRET)
# JWT_DRIVER_SECRET="change-me-driver"
# JWT_DRIVER_ACCESS_EXPIRES_IN="15m"
# JWT_DRIVER_REFRESH_EXPIRES_DAYS=60

# --- Módulo de BI (Apache Superset) --------------------------------------
# URL interna do Superset (em dev, suba o stack ou aponte para um Superset local).
# SUPERSET_BASE_URL=http://localhost:8088
# URL pública usada pelo iframe embutido no painel.
# SUPERSET_PUBLIC_URL=http://localhost:8088
# Service account (admin do Superset) usado para gerar guest tokens.
# SUPERSET_API_USER=admin
# SUPERSET_API_PASSWORD=admin

# --- Oracle (opcional) ---------------------------------------------------
# Caminho para o diretório do Oracle Instant Client. Necessário se o servidor
# Oracle usar o password verifier 12C (erro NJS-116 em modo thin). Quando
# definida, a API ativa o "thick mode" do node-oracledb na inicialização.
# Exemplo Windows: ORACLE_CLIENT_LIB_DIR="C:\\oracle\\instantclient_21_15"
# Exemplo Linux:   ORACLE_CLIENT_LIB_DIR="/opt/oracle/instantclient_21_15"
# ORACLE_CLIENT_LIB_DIR=

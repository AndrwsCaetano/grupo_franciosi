{
  "expo": {
    "name": "New Agrigestão — Ponto",
    "slug": "posto",
    "owner": "suporte.ti.oilema",
    "scheme": "posto",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#FFFFFF",
    "splash": {
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tech.agrigestao.posto",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Usamos a câmera para ler QR Codes das máquinas."
      }
    },
    "android": {
      "package": "tech.agrigestao.posto",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite ler QR Codes de máquinas para abastecimento."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aa4ffb4d-6459-41b8-862c-c3f261e15692"
      }
    }
  }
}

# URL base da API (Nest). Em emulador Android, prefira o IP da rede local
# (10.0.2.2 aponta para o host apenas em AVD). Em iOS Simulator, 127.0.0.1 funciona.
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

# Produção (exemplo — o Traefik/nginx do web-admin já expõe /auth,
# /fuel-station, etc. no mesmo host do painel):
#   EXPO_PUBLIC_API_URL=https://SEU-PROJETO.agrigestao.tech
#
# O APK é genérico (multi-projeto): não embuta URL de cliente no build.
# O operador define o servidor pela engrenagem na tela de login
# (ou em Config → API → Trocar servidor).

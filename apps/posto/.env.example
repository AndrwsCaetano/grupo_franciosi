# URL base da API (Nest). Em emulador Android, prefira o IP da rede local
# (10.0.2.2 aponta para o host apenas em AVD). Em iOS Simulator, 127.0.0.1 funciona.
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

# Produção (VPS Grupo Franciosi — Traefik/nginx do web-admin já expõe /auth,
# /fuel-station, etc. no mesmo host):
#   EXPO_PUBLIC_API_URL=https://grupofranciosi.agrigestao.tech
#
# Este valor também é injetado automaticamente nos builds EAS pelos perfis
# `preview` e `production` (ver `eas.json`). O operador pode substituir em
# tempo de execução em Config → API → URL base.
